#!/usr/bin/env bash

ZIP="08079"
NAME="Pennsville"
LAT=39.653
LON=-75.516

CACHE="/tmp/weather_cache_08079.json"
MAX_AGE=600

GREEN="\033[1;32m"
BLUE="\033[1;34m"
YELLOW="\033[1;33m"
CYAN="\033[1;36m"
MAGENTA="\033[1;35m"
RED="\033[1;31m"
RESET="\033[0m"

API_URL="https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&current_weather=true&hourly=temperature_2m&daily=temperature_2m_max,temperature_2m_min,weathercode,precipitation_probability_max,sunrise,sunset&temperature_unit=fahrenheit&windspeed_unit=mph&timezone=auto"

# ----- Cache -----
if [[ -f "$CACHE" && $(( $(date +%s) - $(stat -c %Y "$CACHE") )) -lt $MAX_AGE ]]; then
    WEATHER=$(cat "$CACHE")
else
    WEATHER=$(curl -s "$API_URL")
    echo "$WEATHER" > "$CACHE"
fi

# ----- Current -----
TEMP=$(echo "$WEATHER" | jq -r '.current_weather.temperature')
WIND=$(echo "$WEATHER" | jq -r '.current_weather.windspeed')
WINDDIR=$(echo "$WEATHER" | jq -r '.current_weather.winddirection')
CURCODE=$(echo "$WEATHER" | jq -r '.current_weather.weathercode')

SUNRISE=$(echo "$WEATHER" | jq -r '.daily.sunrise[0]' | cut -dT -f2)
SUNSET=$(echo "$WEATHER" | jq -r '.daily.sunset[0]' | cut -dT -f2)

# ----- Wind Arrow -----
wind_arrow() {
  deg=$1
  case $(( (deg + 22) / 45 % 8 )) in
    0) echo "↑ N" ;;
    1) echo "↗ NE" ;;
    2) echo "→ E" ;;
    3) echo "↘ SE" ;;
    4) echo "↓ S" ;;
    5) echo "↙ SW" ;;
    6) echo "← W" ;;
    7) echo "↖ NW" ;;
  esac
}

# ----- Description -----
desc() {
  case $1 in
    0) echo "Clear" ;;
    1|2|3) echo "Partly Cloudy" ;;
    45|48) echo "Fog" ;;
    51|53|55) echo "Drizzle" ;;
    61|63|65) echo "Rain" ;;
    71|73|75) echo "Snow" ;;
    80|81|82) echo "Showers" ;;
    95) echo "Thunderstorm" ;;
    *) echo "Unknown" ;;
  esac
}

# ----- Moon Phase (simple lunar cycle approx) -----
DAY_OF_YEAR=$(date +%j)
MOON_INDEX=$(( DAY_OF_YEAR % 29 ))

if (( MOON_INDEX < 2 )); then MOON="🌑 New Moon"
elif (( MOON_INDEX < 7 )); then MOON="🌒 Waxing Crescent"
elif (( MOON_INDEX < 9 )); then MOON="🌓 First Quarter"
elif (( MOON_INDEX < 14 )); then MOON="🌔 Waxing Gibbous"
elif (( MOON_INDEX < 16 )); then MOON="🌕 Full Moon"
elif (( MOON_INDEX < 21 )); then MOON="🌖 Waning Gibbous"
elif (( MOON_INDEX < 23 )); then MOON="🌗 Last Quarter"
else MOON="🌘 Waning Crescent"
fi

# ----- Severe Weather Detection -----
ALERT=""
if [[ "$CURCODE" == "95" ]]; then
  ALERT="${RED}⚠ SEVERE WEATHER: Thunderstorm detected!${RESET}"
fi

clear
echo
echo -e "${GREEN}Location:${RESET}    $NAME ($ZIP)"
echo -e "${YELLOW}Now:${RESET}         ${TEMP}°F  |  $(desc $CURCODE)"
echo -e "Wind:        ${WIND} mph  $(wind_arrow $WINDDIR)"
echo -e "${MAGENTA}Sunrise:${RESET}     $SUNRISE"
echo -e "${MAGENTA}Sunset:${RESET}      $SUNSET"
echo -e "Moon:        $MOON"
[[ -n "$ALERT" ]] && echo -e "$ALERT"

# ----- Hourly Graph -----
echo
echo -e "${CYAN}Hourly Temperature (Next 24h):${RESET}"

HOURS=$(echo "$WEATHER" | jq -r '.hourly.time[0:24][]?')
TEMPS=$(echo "$WEATHER" | jq -r '.hourly.temperature_2m[0:24][]?')

if [[ -n "$TEMPS" ]]; then
  paste <(echo "$HOURS") <(echo "$TEMPS") | while read H T; do
    HOUR=$(date -d "$H" +"%H:%M")
    BAR_LEN=$(printf "%.0f" "$(echo "$T / 2" | bc -l)")
    BAR=$(printf "%-${BAR_LEN}s" "#" )
    printf "%s | %5.1f°F | %s\n" "$HOUR" "$T" "$BAR"
  done
else
  echo "Hourly data unavailable."
fi

# ----- 7 Day Forecast -----
echo
echo -e "${CYAN}7-Day Forecast:${RESET}"
echo "--------------------------------------------------------------------"

for i in {0..6}; do
    DATE=$(echo "$WEATHER" | jq -r ".daily.time[$i]")
    HIGH=$(echo "$WEATHER" | jq -r ".daily.temperature_2m_max[$i]")
    LOW=$(echo "$WEATHER" | jq -r ".daily.temperature_2m_min[$i]")
    CODE=$(echo "$WEATHER" | jq -r ".daily.weathercode[$i]")
    POP=$(echo "$WEATHER" | jq -r ".daily.precipitation_probability_max[$i]")

    DAY=$(date -d "$DATE" +"%a")

    printf "%-10s High: %-5s°F  Low: %-5s°F  Rain: %-3s%%  %s\n" \
           "$DAY" "$HIGH" "$LOW" "$POP" "$(desc $CODE)"
done

echo
echo -e "${BLUE}Updated:${RESET} $(date '+%Y-%m-%d %H:%M:%S')"
echo
